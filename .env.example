# Copy this file to .env and fill in real values. Never commit .env.
# Only the variables listed here are read by the app at build/runtime.

# Supabase — from your Supabase project settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Google OAuth — Web client ID only. The client secret is NOT used in the
# frontend and must never be placed here; it belongs in server-side code.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google Maps JavaScript API key. Restrict by HTTP referrer in Google Cloud
# Console to your production and preview domains before deploying.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# ---------------------------------------------------------------------------
# Server-side only — NOT Vite vars. These are Supabase Edge Function secrets
# consumed by supabase/functions/ai-fuel-prices. They must NEVER be prefixed
# with VITE_ or placed in the frontend .env, or they ship in the public bundle.
#
# Set for production:
#   supabase secrets set OPENROUTER_API_KEY=sk-or-...
#   supabase secrets set OPENROUTER_MODEL=perplexity/sonar   (optional)
# Local dev: put these in supabase/functions/.env (gitignored).
#
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=perplexity/sonar
